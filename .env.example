# Matrix Treasury Environment Configuration

# Environment
ENVIRONMENT=production

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=matrix_treasury
DB_USER=matrix
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=info

# Security
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION

# API Token Authentication (ecosystem-standard Bearer token)
# Required in production/staging - pick one:
MATRIX_TREASURY_TOKEN=CHANGE_ME_IN_PRODUCTION
# Alternative token names (checked in fallback order):
# MATRIX_HUB_TOKEN=
# MATRIX_TOKEN=
# API_TOKEN=
# ADMIN_TOKEN=

# CORS Configuration (comma-separated origins, empty for "*")
CORS_ALLOW_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
CORS_ALLOW_CREDENTIALS=false

# Cost Oracle (Update periodically)
ELECTRICITY_USD_PER_KWH=0.15
PUE=1.20
GPU_USD_PER_HOUR=2.50
AVG_GPU_WATTS=450.0

# ============================================================================
# AUTONOMOUS SURVIVAL UPGRADE - NEW CONFIGURATION
# ============================================================================

# Blockchain Connection (Base/Polygon/Base-Sepolia)
RPC_URL=https://mainnet.base.org
TREASURY_PRIVATE_KEY=0xYourPrivateKeyHere
NETWORK=base

# ETH Price Oracle (for gas estimation)
ETH_USD_PRICE=2000

# LLM Provider Configuration
# Options: ollama (default), openai, claude, watsonx
CFO_PROVIDER=ollama
LLM_PROVIDER=ollama

# OpenAI Configuration
OPENAI_API_KEY=sk-YourOpenAIKeyHere
CFO_OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # Optional: for Azure OpenAI or proxies

# Claude (Anthropic) Configuration
ANTHROPIC_API_KEY=sk-ant-YourClaudeKeyHere
CFO_CLAUDE_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=  # Optional: for proxies

# WatsonX.ai Configuration
WATSONX_API_KEY=YourWatsonXAPIKey
WATSONX_PROJECT_ID=YourProjectID
CFO_WATSONX_MODEL=ibm/granite-3-8b-instruct
WATSONX_BASE_URL=https://us-south.ml.cloud.ibm.com

# Ollama Configuration (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
CFO_OLLAMA_MODEL=llama3

# Akash Infrastructure
AKASH_PROVIDER_ADDRESS=akash1...
AKASH_DAILY_COST_USD=1.50

# Economic Parameters
MXU_TO_USD_EXCHANGE_RATE=0.01  # 1 MXU = $0.01 USD
